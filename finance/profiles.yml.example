# LOCAL / CLI fallback only. On the dbt platform (Cloud), connections are
# configured in the UI per environment and this file is ignored.
#
# Copy to ~/.dbt/profiles.yml (or keep here and run `dbt <cmd> --profiles-dir .`).
# Secrets come from environment variables:
#   export DBT_DATABRICKS_HOST="adb-1234567890.12.azuredatabricks.net"
#   export DBT_DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/abc123def456"
#   export DBT_DATABRICKS_TOKEN="dapiXXXXXXXXXXXXXXXXXXXX"

finance:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: main
      schema: "dbt_{{ env_var('USER', 'dev') }}_finance"
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      threads: 8

    prod:
      type: databricks
      catalog: main
      schema: finance
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      threads: 16
