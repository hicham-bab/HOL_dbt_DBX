# LOCAL / CLI fallback only. On the dbt platform (Cloud), connections are
# configured in the UI per environment and this file is ignored.
#
# Copy to ~/.dbt/profiles.yml (or keep it here and run `dbt <command> --profiles-dir .`)
# and fill in your Databricks values. Secrets are read from environment variables
# so nothing sensitive lands in git:
#   export DBT_DATABRICKS_HOST="adb-1234567890.12.azuredatabricks.net"
#   export DBT_DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/abc123def456"
#   export DBT_DATABRICKS_TOKEN="dapiXXXXXXXXXXXXXXXXXXXX"

platform:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: main                                # Unity Catalog catalog (<CATALOG>)
      schema: "dbt_{{ env_var('USER', 'dev') }}"   # personal dev schema, e.g. dbt_hb — never hardcoded in models
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      threads: 8

    prod:
      type: databricks
      catalog: main
      schema: analytics
      host: "{{ env_var('DBT_DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DBT_DATABRICKS_TOKEN') }}"
      threads: 16
